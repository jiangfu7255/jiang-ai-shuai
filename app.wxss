/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

/* 主色调 */
.green { color: #07c160; }
.bg-green { background-color: #07c160; }
.orange { color: #ff6b35; }
.bg-orange { background-color: #ff6b35; }

/* 通用按钮 */
.btn-primary {
  background-color: #07c160;
  color: #fff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}
.btn-primary::after { border: none; }

.btn-orange {
  background-color: #ff6b35;
  color: #fff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}
.btn-orange::after { border: none; }

.btn-outline {
  background-color: transparent;
  color: #07c160;
  border: 2rpx solid #07c160;
  border-radius: 44rpx;
  height: 80rpx;
  line-height: 76rpx;
  font-size: 28rpx;
}
.btn-outline::after { border: none; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

/* 价格 */
.price { color: #ff6b35; font-weight: 600; }
.price-large { font-size: 40rpx; }
.price-unit { font-size: 24rpx; color: #999; }

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.tag-green { background: #e8f8ee; color: #07c160; }
.tag-orange { background: #fff3e8; color: #ff6b35; }
.tag-gray { background: #f0f0f0; color: #999; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
